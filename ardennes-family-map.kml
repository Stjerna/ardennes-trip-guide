<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Ardennes Family Trip 2026 — complete</name>
  <description>Full trip map, 14–21 August 2026 — every place in the guide. Colors: green activities, purple day trips, blue restaurants, yellow friteries, white bakeries, pink ice cream, light-blue bars, diamond gyms/bikes, red shops+emergency.</description>
  <Style id="home"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ylw-stars.png</href></Icon></IconStyle></Style>
  <Style id="act"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href></Icon></IconStyle></Style>
  <Style id="afield"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/purple-circle.png</href></Icon></IconStyle></Style>
  <Style id="resto"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href></Icon></IconStyle></Style>
  <Style id="frit"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ylw-circle.png</href></Icon></IconStyle></Style>
  <Style id="bak"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/wht-circle.png</href></Icon></IconStyle></Style>
  <Style id="ice"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/pink-circle.png</href></Icon></IconStyle></Style>
  <Style id="bar"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ltblu-circle.png</href></Icon></IconStyle></Style>
  <Style id="gym"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/blu-diamond.png</href></Icon></IconStyle></Style>
